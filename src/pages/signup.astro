---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Email Sign-Up">
  <Header />

  <div class="max-w-xl mx-auto p-8">
    <h1 class="text-3xl font-bold">Join Our Mailing List</h1>

    <form class="mt-4 space-y-4">
      <input type="text" placeholder="Name" class="w-full p-2 bg-gray-800" />
      <input type="email" placeholder="Email" class="w-full p-2 bg-gray-800" />
      <button class="bg-white text-black px-4 py-2">Sign Up</button>
    </form>
  </div>

  <Footer />
</BaseLayout>
